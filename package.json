{
  "name": "@chafed/motif",
  "version": "0.1.0",
  "description": "CLI linter for UI/UX design system drift — like ESLint, but for your design tokens",
  "author": "Ryan Cuff",
  "license": "MIT",
  "homepage": "https://github.com/useMotif/motif#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/useMotif/motif.git"
  },
  "bugs": {
    "url": "https://github.com/useMotif/motif/issues"
  },
  "keywords": [
    "linter",
    "design-system",
    "design-tokens",
    "css",
    "tailwind",
    "react",
    "typescript",
    "jsx",
    "tsx",
    "ui",
    "motif"
  ],
  "bin": {
